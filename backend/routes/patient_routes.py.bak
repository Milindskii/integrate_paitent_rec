from fastapi import APIRouter, HTTPException, Depends
from sqlalchemy.orm import Session
from typing import List
import schemas, crud
from database import get_db

router = APIRouter()

# 🔴 ADD THIS NEW ENDPOINT - Patient Registration
@router.post("/register", response_model=schemas.Patient, tags=["Patients"])
def register_patient(patient: schemas.PatientCreate, db: Session = Depends(get_db)):
    try:
        # Check if patient already exists
        existing_patient = crud.get_patient_by_email(db, patient.email)
        if existing_patient:
            raise HTTPException(status_code=400, detail="Email already registered")
        
        # Create new patient
        new_patient = crud.create_patient(db=db, patient=patient)
        return new_patient
    except Exception as e:
        print(f"Error registering patient: {str(e)}")  # For debugging
        raise HTTPException(status_code=500, detail=str(e))

# Your existing endpoints remain the same
@router.get("/patients/{patient_id}", response_model=schemas.Patient, tags=["Patients"])
def get_patient(patient_id: int, db: Session = Depends(get_db)):
    patient = crud.get_patient(db, patient_id)
    if not patient:
        raise HTTPException(status_code=404, detail="Patient not found")
    return patient

@router.get("/appointments/patient/{patient_id}", response_model=List[schemas.Appointment], tags=["Appointments"])
def get_patient_appointments(patient_id: int, db: Session = Depends(get_db)):
    return crud.get_patient_appointments(db, patient_id)

@router.get("/medical-records/patient/{patient_id}", response_model=List[schemas.MedicalRecord], tags=["Medical Records"])
def get_patient_medical_records(patient_id: int, db: Session = Depends(get_db)):
    return crud.get_patient_medical_records(db, patient_id)

@router.get("/prescriptions/patient/{patient_id}", response_model=List[schemas.Prescription], tags=["Prescriptions"])
def get_patient_prescriptions(patient_id: int, db: Session = Depends(get_db)):
    return crud.get_patient_prescriptions(db, patient_id)

@router.get("/lab-tests/patient/{patient_id}", response_model=List[schemas.LabTest], tags=["Lab Tests"])
def get_patient_lab_tests(patient_id: int, db: Session = Depends(get_db)):
    return crud.get_patient_lab_tests(db, patient_id)

@router.get("/billing/patient/{patient_id}", response_model=List[schemas.Bill], tags=["Billing"])
def get_patient_bills(patient_id: int, db: Session = Depends(get_db)):
    return crud.get_patient_bills(db, patient_id)

@router.get("/reports/patient/{patient_id}", tags=["Reports"])
def get_patient_full_report(patient_id: int, db: Session = Depends(get_db)):
    patient = crud.get_patient(db, patient_id)
    if not patient:
        raise HTTPException(status_code=404, detail="Patient not found")
    return {
        "patient": patient,
        "appointments": crud.get_patient_appointments(db, patient_id),
        "medical_records": crud.get_patient_medical_records(db, patient_id),
        "prescriptions": crud.get_patient_prescriptions(db, patient_id),
        "lab_tests": crud.get_patient_lab_tests(db, patient_id),
        "bills": crud.get_patient_bills(db, patient_id),
    }